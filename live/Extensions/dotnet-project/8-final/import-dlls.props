<Project>
  <!-- References shared by DNN and Oqtane -->
  <ItemGroup Condition="'$(PathBin)' != ''">
    <Reference Include="$(PathBin)\ToSic.*.dll" />
    <Reference Include="$(PathBin)\Connect.Koi.dll" Condition="Exists('$(PathBin)\Connect.Koi.dll')" />
    <Reference Include="$(PathBin)\CsvHelper.dll" Condition="Exists('$(PathBin)\CsvHelper.dll')" />
    <Reference Include="$(PathBin)\System.Collections.Immutable.dll" Condition="Exists('$(PathBin)\System.Collections.Immutable.dll')" />
    <Reference Include="$(PathBin)\System.Text.Json.dll" Condition="Exists('$(PathBin)\System.Text.Json.dll')" />
    <Reference Include="$(PathBin)\System.Memory.dll" Condition="Exists('$(PathBin)\System.Memory.dll')" />
  </ItemGroup>

  <!-- References from the app specific Dependencies folder (incomplete feature) -->
  <ItemGroup>
    <Reference Include="Dependencies\*.dll" />
  </ItemGroup>
</Project>
